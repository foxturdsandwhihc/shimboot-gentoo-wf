#!/bin/bash

# gentoo-update - Convenient wrapper for updating a minimal Gentoo shimboot system
# shimboot-gentoo-2

set -e
if [ "$EUID" -ne 0 ]; then
  exec sudo "$0" "$@"
fi

_log()  { printf '\033[1;32m[update] %s\033[0m\n' "$*"; }
_warn() { printf '\033[1;33m[update] WARN: %s\033[0m\n' "$*" >&2; }
_step() { printf '\n\033[1;34m ====> %s\033[0m\n' "$*"; }

JOBS="${1:-$(nproc)}"

_log "shimboot-gentoo-2 :: Gentoo System Updater"
_log "Jobs: $JOBS"

_step "Syncing portage tree"
emerge-webrsync --verbose || emerge --sync

_step "Updating @world (binary packages preferred)"
emerge --verbose --ask=n \
  --getbinpkg \
  --binpkg-respect-use=y \
  --update --deep --newuse \
  --jobs="$JOBS" \
  --with-bdeps=n \
  @world

_step "Cleaning up old packages"
emerge --depclean --verbose --ask=n 2>/dev/null || _warn "depclean had issues"

_step "Cleaning package cache"
eclean-dist --destructive 2>/dev/null || true
eclean-pkg --destructive 2>/dev/null || true

_log "System update complete!"
