#!/bin/bash

# expand_rootfs - Expand the shimboot root filesystem to fill available disk
# shimboot-gentoo-2: verbose, LUKS-aware

set -e
if [ "$DEBUG" ]; then
  set -x
fi

_log()  { printf '\033[1m[expand] %s\033[0m\n' "$*"; }
_warn() { printf '\033[1;33m[expand] WARN: %s\033[0m\n' "$*" >&2; }
_err()  { printf '\033[1;31m[expand] ERROR: %s\033[0m\n' "$*" >&2; exit 1; }

if [ "$EUID" -ne 0 ]; then
  _err "This script must be run as root. Try: sudo expand_rootfs"
fi

_log "Detecting root filesystem..."
root_dev="$(findmnt -T / -no SOURCE)"
_log "Root device: $root_dev"

luks="$(echo "$root_dev" | grep "/dev/mapper" || true)"

if [ "$luks" ]; then
  _log "Root partition is LUKS-encrypted."
  kname_dev="$(lsblk --list --noheadings --paths --output KNAME "$root_dev")"
  kname="$(basename "$kname_dev")"
  _log "LUKS kname: $kname"
  part_dev="/dev/$(basename "/sys/class/block/$kname/slaves/"*)"
  _log "Underlying partition: $part_dev"
else
  part_dev="$root_dev"
fi

disk_dev="$(lsblk --list --noheadings --paths --output PKNAME "$part_dev" | head -n1)"
part_num="$(echo "${part_dev#$disk_dev}" | tr -d 'p')"

_log "Disk device    : $disk_dev"
_log "Partition dev  : $part_dev"
_log "Partition num  : $part_num"

echo ""
echo "Detected disk layout:"
fdisk -l "$disk_dev" 2>/dev/null | grep "${disk_dev}:" -A 1
echo ""
echo "Detected root partition:"
fdisk -l "$disk_dev" 2>/dev/null | grep "${part_dev}"
echo ""
echo "Current disk usage:"
df -h /
echo ""

read -rp "Press ENTER to expand the rootfs, or Ctrl+C to cancel. "

echo ""
_log "Expanding partition $part_dev on $disk_dev (partition #$part_num)..."
growpart "$disk_dev" "$part_num" && _log "growpart: OK" \
  || _warn "growpart returned non-zero (may already be max size)"

if [ "$luks" ]; then
  _log "Resizing LUKS container..."
  if [ -f "/bootloader/bin/cryptsetup" ]; then
    /bootloader/bin/cryptsetup resize "$root_dev" && _log "cryptsetup resize: OK"
  else
    cryptsetup resize "$root_dev" && _log "cryptsetup resize: OK"
  fi
fi

_log "Resizing ext4 filesystem..."
resize2fs "$root_dev" && _log "resize2fs: OK" \
  || _warn "resize2fs returned non-zero"

echo ""
_log "New disk usage:"
df -h /
echo ""
_log "Root filesystem expansion complete!"
